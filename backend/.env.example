# ── LLM Provider ──────────────────────────────────────────────
LLM_PROVIDER=gemini   # gemini | openai | ollama

# Gemini (used when LLM_PROVIDER=gemini)
GOOGLE_GEMINI_API_KEY=your-gemini-api-key-here   # https://aistudio.google.com/apikey
GEMINI_MODEL=gemini-2.5-flash   # optional — override the Gemini model name

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=your-openai-api-key-here   # https://platform.openai.com/api-keys
OPENAI_MODEL=gpt-4o-mini   # optional — override the OpenAI model name

# Ollama (used when LLM_PROVIDER=ollama) — run `ollama serve` and `ollama pull <model>` locally first, no API key needed
OLLAMA_BASE_URL=http://localhost:11434   # optional — Ollama server address
OLLAMA_MODEL=llama3.2   # optional — any model you've pulled, e.g. qwen2.5, gemma2, mistral — must already be pulled via `ollama pull <model>`

# ── STT (Speech-to-Text) Provider ────────────────────────────
STT_PROVIDER=google   # google | local

# Local STT (used when STT_PROVIDER=local) — runs on-device via faster-whisper, no API key/internet needed
WHISPER_MODEL_SIZE=base   # optional — tiny | base | small | medium | large-v3 (bigger = more accurate, slower, more RAM)
WHISPER_DEVICE=cpu   # optional — cpu | cuda (cuda requires an NVIDIA GPU + CUDA toolkit installed)

# ── TTS (Text-to-Speech) Provider ────────────────────────────
TTS_PROVIDER=google   # google | local

# Local TTS (used when TTS_PROVIDER=local) — uses the OS's built-in voices via pyttsx3, no API key/internet needed
# NOTE: local TTS synthesizes the whole reply before returning (no true streaming) and returns a
# full WAV file — fine for /api/voice/chat, but /ws/voice clients expecting headerless raw PCM
# (e.g. ESP32 firmware) would need updating to handle a WAV header if this is used over that path.
LOCAL_TTS_VOICE=   # optional — a system voice id/name (leave blank for the OS default; on macOS run `say -v '?'` to list options)

# ── Google Cloud (used when STT_PROVIDER=google and/or TTS_PROVIDER=google) ──
GOOGLE_TTS_API_KEY=your-google-cloud-tts-api-key-here   # Google Cloud Console → enable "Cloud Text-to-Speech API" AND "Cloud Speech-to-Text API" → Credentials → API key

# ── Other ─────────────────────────────────────────────────────
TAVILY_API_KEY=your-tavily-api-key-here
TELEGRAM_BOT_TOKEN=your-telegram-bot-token   # optional — get from @BotFather on Telegram
DASHBOARD_ACCESS_KEY=choose-a-long-random-string   # protects /dashboard — if unset, a temporary one is generated and logged at startup
